# EditorConfig - Configuration cohérente pour tous les éditeurs
# https://editorconfig.org

root = true

# Paramètres par défaut pour tous les fichiers
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# TypeScript/JavaScript
[*.{ts,js,mjs,cjs}]
indent_size = 2

# JSON
[*.json]
indent_size = 2

# YAML
[*.{yml,yaml}]
indent_size = 2

# Markdown - Conserver les espaces en fin de ligne (syntaxe Markdown)
[*.md]
trim_trailing_whitespace = false

# Makefiles - Utiliser des tabs
[Makefile]
indent_style = tab

# Shell scripts
[*.sh]
indent_size = 2
