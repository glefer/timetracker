{
  "compilerOptions": {
    "lib": ["deno.window", "dom"]
  },
  "imports": {
    "hono": "https://esm.sh/hono@4.6.16",
    "hono/": "https://esm.sh/hono@4.6.16/",
    "@bunny.net/edgescript-sdk": "https://esm.sh/@bunny.net/edgescript-sdk@0.12.0",
    "@libsql/client/web": "https://esm.sh/@libsql/client@0.14.0/web",
    "pdf-lib": "https://esm.sh/pdf-lib@1.17.1",
    "esbuild": "npm:esbuild@0.25.3",
    "@luca/esbuild-deno-loader": "jsr:@luca/esbuild-deno-loader@^0.11.1",
    "@std/assert": "jsr:@std/assert@^1.0.19"
  },
  "tasks": {
    "dev":   "deno run --allow-net --allow-env src/main.ts",
    "check": "deno check src/main.ts",
    "lint":  "deno lint",
    "test":  "deno test --permit-no-files -A src/**/*.test.ts",
    "build": "mkdir -p dist && deno run -A build.mjs"
  }
}
